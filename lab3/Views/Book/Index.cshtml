@model PagedList.IPagedList<lab3.Models.book>
@using PagedList.Mvc;
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* Định dạng lại khung bọc từng cuốn sách cho chuyên nghiệp */
    .book-panel {
        background: #fff;
        border-radius: 8px;
        padding: 15px;
        margin-bottom: 30px;
        box-shadow: 0 2px 5px rgba(0,0,0,0.05);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        border: 1px solid #e0e0e0;
    }

        .book-panel:hover {
            transform: translateY(-5px);
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }

    .book-title {
        font-size: 16px;
        font-weight: bold;
        height: 44px; /* Giới hạn chiều cao để các khung đều nhau */
        overflow: hidden;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        color: #333;
        margin-bottom: 8px;
    }

    .book-img {
        width: 100%;
        height: 250px;
        object-fit: contain; /* Đổi sang contain để không bị mất góc ảnh sách */
        background-color: #f8f9fa;
        border-radius: 6px;
        margin-bottom: 12px;
    }

    .book-price {
        font-size: 16px;
        color: #cd1818; /* Màu đỏ đặc trưng Fahasa */
        font-weight: bold;
    }

    .book-stock {
        font-size: 13px;
        color: #666;
    }

    /* Tinh chỉnh thanh phân trang theo tông màu đỏ/cam Fahasa */
    .pagination-container {
        text-align: center;
        margin-top: 40px;
        margin-bottom: 20px;
    }

    .pagination {
        display: inline-flex;
        gap: 5px;
        padding-left: 0;
        list-style: none;
    }

        .pagination li a,
        .pagination li span {
            padding: 8px 14px;
            border-radius: 6px;
            border: 1px solid #e0e0e0;
            background-color: white;
            color: #333;
            text-decoration: none;
            font-weight: bold;
        }

            .pagination li a:hover {
                background-color: #cd1818;
                border-color: #cd1818;
                color: white !important;
            }

        .pagination > .active > a,
        .pagination > .active > span {
            background-color: #cd1818 !important;
            border-color: #cd1818 !important;
            color: white !important;
        }

    /* Tiêu đề trang */
    .page-main-title {
        font-size: 22px;
        font-weight: bold;
        color: #333;
        border-left: 4px solid #cd1818;
        padding-left: 10px;
        margin-bottom: 25px;
        text-transform: uppercase;
    }
</style>

<h2 class="page-main-title">HUTECH LIBRARY</h2>

<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-lg-4 col-md-4 col-sm-6">
            <div class="book-panel">

                <a href="@Url.Action("Detail", "Book", new { id = item.book_id })">
                    <img src="@item.image" class="book-img" alt="@item.book_name" onerror="this.src='https://placehold.co/300x400?text=No+Image'" />
                </a>

                <div class="book-title">
                    @item.book_name
                </div>

                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="book-price">@item.price VNĐ</span>
                    <span class="book-stock">Kho: <strong>@item.quantity_instock</strong></span>
                </div>

                <div class="text-center d-flex gap-2 justify-content-center">
                    @Html.ActionLink("Chi tiết", "Detail", new { id = item.book_id }, new { @class = "btn btn-sm btn-outline-secondary" })

                    <a class="btn btn-sm btn-danger"
                       href="@Url.Action("AddCart", "Cart", new { id = item.book_id, strURL = Request.RawUrl })">
                        <i class="bi bi-cart-plus"></i> Mua ngay
                    </a>

                    @Html.ActionLink("Xóa", "Delete", new { id = item.book_id }, new { @class = "btn btn-sm btn-link text-muted", onclick = "return confirm('Bạn có chắc muốn xóa sách này?');" })
                </div>

            </div>
        </div>
    }
</div>

<div class="pagination-container">
    @Html.PagedListPager(
        Model,
        page => Url.Action(
            "Index",
            new
            {
                page,
                size = ViewBag.Size,
                searchString = ViewBag.Keyword
            }))
</div>