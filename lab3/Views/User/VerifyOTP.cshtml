@{
    ViewBag.Title = "Xác Minh Email - Fahasa Hutech";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center" style="margin-top: 60px; margin-bottom: 60px;">
    <div class="col-md-6 col-md-offset-3 col-lg-4 col-lg-offset-4">
        <div class="panel panel-default shadow-sm" style="padding:30px; background: #ffffff; border: 1px solid #e0e0e0; border-radius: 8px;">

            <div class="text-center mb-4">
                <i class="bi bi-envelope-check" style="font-size: 50px; color: #cd1818;"></i>
                <h3 style="margin-top: 15px; font-weight: bold; color: #333;">Xác Minh Tài Khoản</h3>
                <p class="text-muted" style="font-size: 14px;">Một mã xác thực OTP gồm 6 chữ số đã được gửi đến Email của bạn. Vui lòng kiểm tra và nhập vào ô dưới đây.</p>
            </div>

            <hr style="border-top: 1px solid #eee;" />

            @using (Html.BeginForm("VerifyOTP", "User", FormMethod.Post))
            {
                @Html.AntiForgeryToken()

                if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger text-center" style="font-size: 13px; padding: 10px; border-radius: 5px;">
                        <i class="bi bi-exclamation-triangle-fill"></i> @ViewBag.Error
                    </div>
                }

                <div class="form-group text-center">
                    <label class="control-label" style="font-weight: bold; display: block; margin-bottom: 15px; color: #555;">Nhập mã OTP 6 số</label>
                    <input type="text"
                           name="enteredOTP"
                           class="form-control text-center"
                           placeholder="000000"
                           maxlength="6"
                           required
                           autocomplete="off"
                           style="font-size: 24px; font-weight: bold; letter-spacing: 6px; border: 2px solid #ccc; border-radius: 6px; height: 50px; color: #333;" />
                </div>

                <button type="submit" class="btn btn-danger btn-block" style="margin-top: 25px; width:100%; height: 45px; font-weight: bold; background-color: #cd1818; border-color: #cd1818; font-size: 16px; border-radius: 6px;">
                    Xác Nhận & Đăng Ký
                </button>
            }

            <div class="text-center" style="margin-top: 20px;">
                <a href="@Url.Action("Register", "User")" style="font-size: 13px; color: #666; text-decoration: none;">
                    <i class="bi bi-arrow-left"></i> Quay lại trang đăng ký
                </a>
            </div>
        </div>
    </div>
</div>