@model IEnumerable<lab3.Models.Cart>
@{
    ViewBag.Title = "Place Order";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Your Cart Summary</h2>
<table class="table">
    <tr>
        <th>@Html.DisplayNameFor(model => model.book_name)</th>
        <th>@Html.DisplayNameFor(model => model.image)</th>
        <th>@Html.DisplayNameFor(model => model.price)</th>
        <th>@Html.DisplayNameFor(model => model.iquantity)</th>
        <th>@Html.DisplayNameFor(model => model.Total)</th>
        <th></th>
    </tr>
    @foreach (var item in Model)
    {
        <tr>
            <td> @Html.DisplayFor(modelItem => item.book_name) </td>
            <td> <img src="@item.image" width="120" /> </td>
            <td> @String.Format("{0:0,0}", item.price) USD </td>

            <td>
                @using (Html.BeginForm("CartUpdate", "Cart", new { id = item.book_id }, FormMethod.Post))
                {
                    <div style="display: flex; gap: 5px;">
                        <input type="number" min="1" name="txtSoLg" value="@item.iquantity" class="form-control" style="width:70px; display:inline-block;" />
                        <input type="submit" value="Update" class="btn btn-success btn-sm" />
                    </div>
                }
            </td>

            <td> @String.Format("{0:0,0}", item.Total) USD </td>
            <td>
                @Html.ActionLink("Delete", "CartDelete", new { id = item.book_id }, new { @class = "text-danger" })
            </td>
        </tr>
    }
    <tr style="font-weight:bold; text-align:left; color:red">
        <td colspan="2"> Quantity Sum: @ViewBag.sumProductQuantity </td>
        <td colspan="2"> Quantity Total: @ViewBag.sumQuantity </td>
        <td colspan="2"> Total: @String.Format("{0:0,0}", @ViewBag.Total) USD </td>
    </tr>
    <tr style="font-weight:bold; color:blue; text-align:right ">
        <td colspan="6">
            @Html.ActionLink("Back to Cart", "Cart", "Cart", null, new { @class = "btn btn-default" })
        </td>
    </tr>
</table>

@using lab3.Models
<h2 style="text-align:center; margin-top:40px; font-weight:bold; color:#2c3e50;">Information of Place an order</h2>

@{
    customer kh = (customer)Session["User"];
}

@if (kh == null)
{
    <div class="alert alert-warning text-center">
        <h4>You must log in to confirm the order!</h4>
        <a href="@Url.Action("Login", "User")" class="btn btn-danger">Click here to Login</a>
    </div>
}
else
{
    using (Html.BeginForm("PlaceOrder", "Cart", FormMethod.Post))
    {
        @Html.ValidationSummary(true)
        <table align="center" style="width: 50%; background-color: #f8f9fa; padding: 20px; border-radius: 8px; border: 1px solid #dee2e6;">
            <tr style="height:40px">
                <td style="padding-left:15px;">Customer name:</td>
                <td style="font-weight:bold">@kh.customer_name</td>
            </tr>
            <tr style="height:40px">
                <td style="padding-left:15px;">Email:</td>
                <td style="font-weight:bold">vukhanhhoang8888@gmail.com</td>
            </tr>
            <tr style="height:40px">
                <td style="padding-left:15px;">Address:</td>
                <td style="font-weight:bold">@kh.address</td>
            </tr>
            <tr style="height:40px">
                <td style="padding-left:15px;">Number phone:</td>
                <td style="font-weight:bold">@kh.numberphone</td>
            </tr>
            <tr style="height:40px">
                <td style="padding-left:15px;">Order date:</td>
                <td style="font-weight:bold; color: blue;">@DateTime.Now.ToShortDateString()</td>
            </tr>
            <tr style="height:45px">
                <td style="padding-left:15px;">Delivery date:</td>
                <td>
                    <input type="date" name="delivery_date" required class="form-control" style="width: 200px;" />
                </td>
            </tr>
            <tr style="height:50px">
                <td></td>
                <td>
                    <input type="submit" value="Confirm Order" class="btn btn-success btn-lg" style="width: 200px; font-weight: bold;" />
                </td>
            </tr>
        </table>
    }
}