@model IEnumerable<lab3.Models.StatisticDTO>
@{
    ViewBag.Title = "Statistic";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2 style="margin-top:20px; font-weight:bold; color:#2c3e50;">Statistic of Sale Book Quantity</h2>

<table class="table table-striped table-bordered" style="width:100%; margin-top:20px;">
    <thead>
        <tr style="background-color: #f8f9fa;">
            <th style="font-weight: bold; font-size: 16px;">Book Name</th>
            <th style="font-weight: bold; font-size: 16px; text-align: right; width: 250px;">Sale Quantity</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null)
        {
            foreach (var item in Model)
            {
                <tr>
                    <td style="font-size: 15px; vertical-align: middle;">@item.BookName</td>
                    <td style="font-size: 15px; text-align: right; font-weight: bold; color: #27ae60; vertical-align: middle;">
                        @item.SaleQuantity
                    </td>
                </tr>
            }
        }
    </tbody>
</table>